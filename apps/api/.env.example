PORT=4000
# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/nutrition_app?retryWrites=true&w=majority

# Auth — change this to a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret

# AI analysis (Gemini — free tier available at aistudio.google.com)
GEMINI_API_KEY=

# Email — Gmail (free, 500 emails/day)
# Step 1: Create a Gmail account (or use existing)
# Step 2: Enable 2-Step Verification in Google Account → Security
# Step 3: Go to Security → App passwords → Mail → generate 16-char password
# Step 4: Fill in your Gmail address and the App Password below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# Alternative: Brevo (300 emails/day free — brevo.com → SMTP & API)
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=your-brevo-login@email.com
# SMTP_PASS=your-brevo-smtp-key
